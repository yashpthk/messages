</div>

<div id="validationOverlay">
  <button id="validationClose" type="button" onclick="closeValidation()">✕</button>
  <div id="validationText"></div>
</div>

<div id="charismaOverlay">
  <button id="charismaClose" type="button" onclick="closeCharisma()">✕</button>
  <div id="charismaText"></div>
  <div id="charismaMeter"><div id="charismaFill"></div></div>
  <div id="charismaSub"></div>
</div>

<div id="fortuneOverlay">
  <button id="fortuneClose" type="button" onclick="closeFortune()">✕</button>
  <div id="fortuneText"></div>
</div>

<div id="chaosOverlay">
  <button id="chaosClose" type="button" onclick="closeChaos()">✕</button>
  <div>
    <div id="chaosText"></div>
    <div id="chaosSub"></div>
  </div>
</div>

<div id="duckOverlay"></div>

<script>

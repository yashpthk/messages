];

const PASSWORD_HASH = 'a3ecbba54d84a5c73c49fc513c02b333b924ed64f79b02e572a38c9ddc1b8651';
const FIRST_UNLOCK_MESSAGE = 'You tapped. So now I get to remind you that you’re one of my favorite people.';

    <button id="actionBtn" class="actionBtn" type="button">Yes</button>
    <button id="refreshBtn" class="refreshBtn" type="button" onclick="showRandomMessage()">↻</button>

    <div id="buttonWrap" class="buttonWrap">
      <div id="impatienceMeter"><div id="impatienceFill"></div></div>
      <button id="nextBtn" class="primaryBtn" type="button" onclick="showRandomMessage()">I am impatient</button>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>☕</title>
<style>
body {
  margin: 0;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #fffafc, #ffffff);
  font-family: Georgia, serif;
  padding: 24px;
  overflow-x: hidden;
}

.card {
  position: relative;
  max-width: 700px;
  width: 100%;
  background: white;
  border-radius: 24px;
  padding: 36px;
  text-align: center;
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
  border: 2px solid transparent;
  z-index: 1;
  transition: background 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
}

.card.specialCard {
  background: #f68dd5;
  box-shadow: 0 12px 30px rgba(246, 141, 213, 0.22);
}

.card.validationCard {
  border-color: #d7b4ff;
  box-shadow: 0 12px 30px rgba(181, 135, 255, 0.18);
}

.card.charismaCard {
  border-color: #f2c66d;
  box-shadow: 0 12px 30px rgba(242, 198, 109, 0.22);
}

.card.fortuneCard {
  border-color: #9cc8ff;
  box-shadow: 0 12px 30px rgba(116, 170, 255, 0.18);
}

.card.chaosCard {
  border-color: #7fe0bf;
  box-shadow: 0 12px 30px rgba(88, 212, 170, 0.2);
}

input {
  padding: 12px;
  width: 100%;
  max-width: 320px;
  border-radius: 12px;
  border: 1px solid #ddd;
  margin-top: 10px;
  font-size: 16px;
}

button {
  font-size: 0.95rem;
  margin-top: 14px;
  padding: 12px 18px;
  border-radius: 999px;
  cursor: pointer;
}

.primaryBtn {
  border: 1px solid #d9c7d0;
  background: transparent;
  color: #8a7280;
}

.primaryBtn:hover,
.lockBtn:hover,
.refreshBtn:hover {
  background: #fff6fa;
}

.actionBtn {
  display: none;
  margin: 8px auto 0;
  background: #2f2430;
  color: white;
  border: none;
}

.actionBtn:hover,
.quackBtn:hover {
  opacity: 0.92;
}

#messagePage {
  display: none;
}

#message {
  min-height: 4.8em;
  font-size: 1.8rem;
  line-height: 1.5;
  margin: 24px 0;
  opacity: 0;
  transition: opacity 0.4s ease;
}

#message.specialMessage {
  color: #5f3b54;
  font-style: italic;
  font-size: 1.65rem;
  letter-spacing: 0.01em;
}

#message.specialMessage::before {
  content: 'Impatience meter full';
  display: block;
  position: absolute;
  top: 14px;
  left: 36px;
  text-align: left;
  font-family: Arial, sans-serif;
  font-size: 0.72rem;
  font-style: normal;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #7a4d68;
  line-height: 34px;
  height: 34px;
  margin-bottom: 0;
}

.small {
  color: #8a7280;
  font-size: 0.9rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.error {
  color: crimson;
  margin-top: 10px;
}

.hint {
  color: #8a7280;
  margin-top: 10px;
  min-height: 48px;
}

.lockBtn,
.refreshBtn {
  width: 34px;
  height: 34px;
  padding: 0;
  margin: 0;
  border: 1px solid #d9c7d0;
  background: transparent;
  color: #8a7280;
  border-radius: 999px;
  font-size: 14px;
  line-height: 1;
}

.lockBtn {
  position: absolute;
  top: 14px;
  right: 14px;
}

.refreshBtn {
  display: none;
  vertical-align: middle;
  margin-left: 8px;
}

.quackBtn {
  background: #2f2430;
  color: white;
  border: none;
}

.card.specialCard #message,
.card.specialCard .small,
.card.specialCard .hint,
.card.specialCard .primaryBtn,
.card.specialCard .lockBtn,
.card.specialCard .refreshBtn {
  color: #5f3b54;
  border-color: rgba(95, 59, 84, 0.25);
}

.card.specialCard .primaryBtn,
.card.specialCard .lockBtn,
.card.specialCard .refreshBtn {
  color: #6b5612;
  border-color: rgba(107, 86, 18, 0.28);
  background: rgba(255, 245, 196, 0.55);
}

.card.specialCard .actionBtn {
  background: #f2cf63;
  color: #5b4710;
  border: none;
}

.card.specialCard .primaryBtn:hover,
.card.specialCard .lockBtn:hover,
.card.specialCard .refreshBtn:hover {
  background: rgba(255, 241, 173, 0.82);
}

.card.specialCard .actionBtn:hover {
  opacity: 1;
  background: #ecc54a;
}

#validationOverlay,
#charismaOverlay,
#fortuneOverlay,
#chaosOverlay,
#duckOverlay {
  position: fixed;
  inset: 0;
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 20;
}

#validationOverlay,
#charismaOverlay,
#fortuneOverlay,
#chaosOverlay {
  background: rgba(255, 250, 252, 0.92);
  padding: 24px;
  text-align: center;
}

#validationText,
#charismaText,
#fortuneText,
#chaosText {
  max-width: 720px;
  color: #2f2430;
  font-size: clamp(2rem, 5vw, 3.8rem);
  line-height: 1.2;
}

#chaosText {
  max-width: 760px;
}

#chaosSub,
#charismaSub {
  color: #8a7280;
  font-size: 1rem;
  margin-top: 14px;
}

#validationClose,
#charismaClose,
#fortuneClose,
#chaosClose {
  position: absolute;
  top: 22px;
  right: 22px;
  background: transparent;
  color: #8a7280;
  border: 1px solid #d9c7d0;
}

#charismaMeter {
  width: min(420px, 80vw);
  height: 16px;
  margin: 24px auto 14px;
  background: #f2e6ec;
  border-radius: 999px;
  overflow: hidden;
  border: 1px solid #ead6df;
}

#charismaFill {
  width: 0%;
  height: 100%;
  background: linear-gradient(90deg, #f5b8cf, #2f2430);
  transition: width 1.1s ease;
}

#duckOverlay {
  pointer-events: none;
  overflow: hidden;
}

.duck {
  position: absolute;
  font-size: 2rem;
  animation: floatDuck 3.8s linear forwards;
}

@keyframes floatDuck {
  0% { transform: translateY(120vh) rotate(0deg); opacity: 0; }
  10% { opacity: 1; }
  100% { transform: translateY(-20vh) rotate(18deg); opacity: 0; }
}

.buttonWrap {
  width: fit-content;
  margin: 0 auto;
}

#impatienceMeter {
  width: 100%;
  height: 7px;
  margin: 0 auto 10px;
  background: #f3e8ed;
  border-radius: 999px;
  overflow: hidden;
  border: 1px solid #ead9e1;
}

#impatienceFill {
  width: 0%;
  height: 100%;
  background: linear-gradient(90deg, #e6c9d5, #8a7280);
  transition: width 0.28s ease;
}
</style>
</head>
<body>
<div class="card" id="mainCard">
